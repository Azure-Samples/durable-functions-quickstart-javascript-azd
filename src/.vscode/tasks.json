{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "npm install (functions)",
			"type": "shell",
			"command": "npm install",
			"options": {
				"cwd": "${workspaceFolder}/src"
			}
		},
		{
			"type": "func",
			"dependsOn": "npm install (functions)",
			"options": {
				"cwd": "${workspaceFolder}/src"
			},
			"command": "host start",
			"isBackground": true,
			"problemMatcher": "$func-node-watch"
		}
	]
}
